{
  "name": "loomify",
  "version": "1.0.0",
  "description": "Loomify - Gravador de Tela Premium",
  "author": "Loomify",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "vite build",
    "desktop-build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.loomify.recorder",
    "productName": "Loomify",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist-electron",
      "!.git",
      "!vite.config.js"
    ]
  }
}
